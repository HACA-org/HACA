#!/bin/bash
# fcp — Main entry point for FCP-Ref

# Bootstrap: locate FCP_REF_ROOT
if [ -z "${FCP_REF_ROOT:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export FCP_REF_ROOT="$SCRIPT_DIR"
fi

cd "$FCP_REF_ROOT"

case "${1:-}" in
    tui)
        shift
        ./fcp-tui.sh "$@"
        ;;
    cycle)
        shift
        ./core/sil.sh "$@"
        ;;
    endure)
        shift
        case "${1:-}" in
            list)
                python3 - <<'PYEOF'
import json, os, sys
root = os.environ.get("FCP_REF_ROOT", os.getcwd())
proposals_path = os.path.join(root, "state", "pending_proposals.jsonl")
if not os.path.exists(proposals_path):
    print("No pending Evolution Proposals.")
    sys.exit(0)
proposals = []
with open(proposals_path) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        try: proposals.append(json.loads(line))
        except Exception: pass
if not proposals:
    print("No pending Evolution Proposals.")
    sys.exit(0)
# Load authorized proposals
log_path = os.path.join(root, "state", "integrity.log")
auth_ids = set()
try:
    with open(log_path) as f:
        for line in f:
            try:
                e = json.loads(line.strip())
                if e.get("type") == "EVOLUTION_AUTH":
                    d = json.loads(e.get("data","{}"))
                    auth_ids.add(d.get("proposal_id",""))
            except Exception: pass
except Exception: pass
print(f"{'ID':<20} {'STATUS':<12} {'FILE':<40} REASON")
print("-" * 90)
for p in proposals:
    pid    = p.get("proposal_id","")[:18]
    status = "AUTHORIZED" if p.get("proposal_id","") in auth_ids else "PENDING"
    tgt    = p.get("target_file","")[:38]
    reason = p.get("reason","")[:30]
    print(f"{pid:<20} {status:<12} {tgt:<40} {reason}")
PYEOF
                ;;
            approve)
                PROPOSAL_ID="${2:-}"
                if [ -z "$PROPOSAL_ID" ]; then
                    echo "Usage: ./fcp endure approve <proposal_id>" >&2
                    exit 1
                fi
                python3 - "$PROPOSAL_ID" <<'PYEOF'
import hashlib, json, os, sys
from datetime import datetime, timezone

root = os.environ.get("FCP_REF_ROOT", os.getcwd())
pid  = sys.argv[1]

proposals_path = os.path.join(root, "state", "pending_proposals.jsonl")
log_path       = os.path.join(root, "state", "integrity.log")

# Find proposal
proposal = None
try:
    with open(proposals_path) as f:
        for line in f:
            line = line.strip()
            if not line: continue
            try:
                p = json.loads(line)
                if p.get("proposal_id") == pid:
                    proposal = p
                    break
            except Exception: pass
except Exception: pass

if not proposal:
    print(f"Proposal not found: {pid}", file=sys.stderr)
    sys.exit(1)

print(f"\n=== Evolution Proposal: {pid} ===")
print(f"Target:  {proposal.get('target_file','')}")
print(f"Reason:  {proposal.get('reason','')}")
print(f"Digest:  {proposal.get('content_digest','')}")
print(f"\n--- Proposed content ---")
print(proposal.get("content",""))
print("---")

try:
    with open("/dev/tty") as tty:
        sys.stdout.write("\nApprove this proposal? [y/N] ")
        sys.stdout.flush()
        answer = tty.readline().strip().lower()
except Exception:
    answer = ""

if answer != "y":
    print("Proposal not approved.")
    sys.exit(0)

# Load operator identity
op_path = os.path.join(root, "memory", "preferences", "operator.json")
operator = "operator"
try:
    op = json.load(open(op_path))
    operator = op.get("handle") or op.get("name", "operator")
except Exception: pass

ts = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
auth_data = json.dumps({
    "proposal_id":    pid,
    "content_digest": proposal.get("content_digest",""),
    "operator":       operator,
    "approved_at":    ts,
})
entry = {"actor": "sil", "type": "EVOLUTION_AUTH", "ts": ts, "data": auth_data}
with open(log_path, "a") as f:
    json.dump(entry, f)
    f.write("\n")

print(f"EVOLUTION_AUTH written for {pid}.")
print(f"Proposal will execute at next Sleep Cycle Stage 3.")
PYEOF
                ;;
            *)
                echo "Usage: ./fcp endure {list|approve <proposal_id>}" >&2
                exit 1
                ;;
        esac
        ;;
    help|--help|-h)
        echo "Filesystem Cognitive Platform (FCP) - Reference Implementation"
        echo ""
        echo "Usage:"
        echo "  ./fcp tui                          - Start the interactive operator terminal (default)"
        echo "  ./fcp cycle [--dry-run]            - Run a cognitive session"
        echo "  ./fcp endure list                  - List pending Evolution Proposals"
        echo "  ./fcp endure approve <proposal_id> - Authorize an Evolution Proposal"
        echo "  ./fcp help                         - Show this help message"
        echo ""
        echo "Environment Variables:"
        echo "  ANTHROPIC_API_KEY       - Required if using Claude backend"
        echo "  OPENAI_API_KEY          - Required if using OpenAI backend"
        ;;
    *)
        # Default to TUI if no args
        if [ -z "$1" ]; then
            ./fcp-tui.sh
        else
            echo "Unknown command: $1"
            echo "Try './fcp help' for usage."
            exit 1
        fi
        ;;
esac
