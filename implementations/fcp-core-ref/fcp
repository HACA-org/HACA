#!/usr/bin/env python3
"""FCP-Core reference implementation entry point.

Usage:
  ./fcp [entity-root]                  — start interactive session
  ./fcp tui [entity-root]              — start Rich TUI session
  ./fcp doctor [entity-root]           — check structural integrity
  ./fcp doctor --fix [entity-root]     — rebuild Integrity Document after direct edits
  ./fcp [entity-root] --notifications  — list pending notifications
  ./fcp [entity-root] --status         — quick entity status

entity-root defaults to the directory containing this script.
"""

import os
import sys

# Add this script's directory to sys.path so `core` package is importable
# regardless of where the user invokes fcp from.
_HERE = os.path.dirname(os.path.abspath(__file__))
if _HERE not in sys.path:
    sys.path.insert(0, _HERE)

from core.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
