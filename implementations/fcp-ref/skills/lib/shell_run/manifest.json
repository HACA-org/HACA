{
  "name": "shell_run",
  "version": "1.1.0",
  "description": "Execute an allowed shell command within workspace_focus.",
  "timeout_seconds": 30,
  "background": false,
  "irreversible": true,
  "class": "builtin",
  "permissions": [
    "workspace_write"
  ],
  "allowlist": [
    "find",
    "pwd",
    "python3",
    "uv"
  ],
  "allowlist_composite": [],
  "params": {
    "type": "object",
    "properties": {
      "command": {
        "type": "string",
        "description": "Shell command to execute within workspace_focus."
      }
    },
    "required": [
      "command"
    ]
  },
  "execution": "script",
  "dependencies": [
    "python3"
  ]
}
